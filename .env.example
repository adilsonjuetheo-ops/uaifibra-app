# Copie para .env e preencha com os dados reais do IXC da UaiFibra.
# IMPORTANTE: variaveis EXPO_PUBLIC_* do .env NAO vao para builds EAS —
# cadastre-as tambem no ambiente "production" do EAS (eas env:create).

# URL base da API do IXC Soft do provedor (sem barra no final)
EXPO_PUBLIC_IXC_BASE_URL=https://ixc.uaifibratelecom.com.br/webservice/v1

# Token da API REST gerado no painel do IXC
# (Sistema -> Configuracoes -> API REST -> Novo token)
# Formato: "id_do_token:hash_do_token"
EXPO_PUBLIC_IXC_TOKEN=00:PREENCHER_TOKEN_AQUI

EXPO_PUBLIC_APP_NAME=UaiFibra

# WhatsApp do suporte (somente numeros, com DDI 55)
EXPO_PUBLIC_SUPORTE_WHATSAPP=5500000000000
